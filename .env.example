# GitHub stats — fetched at build time
#
# GITHUB_USERNAME (required for the open-source section)
#   Your GitHub handle. Without it, the section is skipped.
#
# GITHUB_TOKEN (optional)
#   A Personal Access Token (classic or fine-grained, scope: read:user, public_repo).
#   Required only for the contributions calendar (GraphQL).
#   Without it: profile, repos and languages still render; the activity sparkline
#   is omitted.
#   Generate at: https://github.com/settings/tokens

GITHUB_USERNAME=your-handle
GITHUB_TOKEN=
