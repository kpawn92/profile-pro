---
interface Props {
  eyebrow?: string;
  title: string;
  align?: 'left' | 'center';
  size?: 'm' | 'l';
}

const { eyebrow, title, align = 'left', size = 'l' } = Astro.props;
---

<header
  class:list={[
    'reveal-init',
    align === 'center' ? 'text-center mx-auto max-w-2xl' : 'max-w-2xl',
  ]}
>
  {
    eyebrow && (
      <p class="eyebrow mb-5 flex items-center gap-3">
        <span class="accent-rule" aria-hidden="true" /> {eyebrow}
      </p>
    )
  }
  <h2
    class:list={[
      'font-display text-balance',
      size === 'l' ? 'text-display-l' : 'text-display-m',
    ]}
  >
    {title}
  </h2>
  <slot />
</header>
