---
interface Props {
  as?: string;
  children?: any;
  staggerChildren?: boolean;
  class?: string;
}

const { as: As = 'div', staggerChildren = false, class: className = '' } = Astro.props;
---

<As
  class:list={['reveal-on-scroll', className]}
  data-reveal-children={staggerChildren ? 'true' : 'false'}
>
  <slot />
</As>

<script>
  import { revealOnScroll } from '@/lib/motion';
  revealOnScroll('.reveal-on-scroll', {
    stagger: 80,
    duration: 700,
    translateY: 16,
  });
</script>
