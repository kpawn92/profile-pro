---
import type { CollectionEntry } from 'astro:content';
import {
  getLangFromUrl,
  useTranslations,
  localizePath,
  formatDate,
} from '@/i18n/utils';

interface Props {
  entry: CollectionEntry<'articles'>;
  variant?: 'default' | 'list';
}

const { entry, variant = 'default' } = Astro.props;
const { data, slug } = entry;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const cleanSlug = slug.replace(/^(en|es)\//, '');
const href = localizePath(`/writing/${cleanSlug}/`, lang);

const dateShort = formatDate(data.pubDate, lang, {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

{
  variant === 'list' ? (
    <a
      href={href}
      class="reveal-init group grid grid-cols-1 sm:grid-cols-[7rem_1fr_auto] gap-2 sm:gap-6 py-6 border-b border-border hover:border-border-strong transition-colors items-baseline"
    >
      <time
        datetime={data.pubDate.toISOString()}
        class="font-mono text-xs text-text-dim sm:pt-1"
      >
        {dateShort}
      </time>
      <div>
        <h3 class="font-display text-xl md:text-2xl leading-tight text-balance group-hover:text-accent transition-colors">
          {data.title}
        </h3>
        <p class="mt-2 text-text-muted text-sm md:text-base leading-relaxed text-pretty">
          {data.description}
        </p>
      </div>
      <span class="hidden md:block font-mono text-xs text-text-dim self-center transition-transform group-hover:translate-x-1">
        →
      </span>
    </a>
  ) : (
    <a
      href={href}
      class="surface-card group flex flex-col h-full p-6 md:p-7 reveal-init"
    >
      <time
        datetime={data.pubDate.toISOString()}
        class="font-mono text-eyebrow uppercase text-text-dim"
      >
        {dateShort} · {data.readingTime} {t('writing.minRead')}
      </time>
      <h3 class="mt-4 font-display text-xl md:text-2xl leading-tight text-balance group-hover:text-accent transition-colors">
        {data.title}
      </h3>
      <p class="mt-3 text-text-muted leading-relaxed text-pretty">
        {data.description}
      </p>
      <div class="mt-auto pt-8 flex items-center justify-end text-xs font-mono text-accent">
        <span class="transition-transform group-hover:translate-x-1">
          {t('writing.read')}
        </span>
      </div>
    </a>
  )
}
