---
import type { GhRepo } from '@/lib/github';

interface Props {
  repo: GhRepo;
}

const { repo } = Astro.props;

const formatNumber = (n: number) => {
  if (n >= 1000) return `${(n / 1000).toFixed(n >= 10000 ? 0 : 1)}k`;
  return n.toString();
};
---

<a
  href={repo.url}
  target="_blank"
  rel="noopener noreferrer"
  class="surface-card group flex flex-col h-full p-6 reveal-init"
>
  <div class="flex items-center justify-between gap-4">
    <span class="font-mono text-eyebrow uppercase text-text-dim truncate">
      <span class="text-accent" aria-hidden="true">/</span>
      <span class="ml-1">{repo.name}</span>
    </span>
    <span class="font-mono text-[11px] text-text-dim shrink-0">
      ★ {formatNumber(repo.stars)}
    </span>
  </div>

  <p class="mt-4 text-sm text-text-muted leading-relaxed text-pretty line-clamp-3 min-h-[3.6em]">
    {repo.description ?? 'No description provided.'}
  </p>

  <div
    class="mt-auto pt-6 flex items-center justify-between text-[11px] font-mono text-text-dim"
  >
    <span class="flex items-center gap-2">
      <span
        class="inline-block w-1.5 h-1.5 rounded-full bg-accent"
        aria-hidden="true"
      />
      <span class="uppercase tracking-wider">{repo.language ?? '—'}</span>
    </span>
    <span class="flex items-center gap-3">
      <span>⑂ {formatNumber(repo.forks)}</span>
      <span class="text-accent transition-transform group-hover:translate-x-0.5">→</span>
    </span>
  </div>
</a>
