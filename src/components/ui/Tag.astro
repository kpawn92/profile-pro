---
interface Props {
  size?: 'sm' | 'md';
  variant?: 'default' | 'accent';
  as?: 'li' | 'span';
}

const { size = 'md', variant = 'default', as: As = 'li' } = Astro.props;

const sizeClass =
  size === 'sm' ? 'text-[11px] px-2.5 py-1' : 'text-xs px-3 py-1.5';
const variantClass =
  variant === 'accent'
    ? 'border-accent/40 text-accent'
    : 'border-border text-text-muted hover:border-border-strong hover:text-text';
---

<As
  data-tag
  class:list={[
    'inline-flex items-center font-mono uppercase tracking-wider border rounded-none transition-colors',
    sizeClass,
    variantClass,
  ]}
>
  <slot />
</As>
