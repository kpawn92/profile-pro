---
import type { CollectionEntry } from 'astro:content';
import Tag from './Tag.astro';
import { getLangFromUrl, useTranslations, localizePath } from '@/i18n/utils';

interface Props {
  entry: CollectionEntry<'case-studies'>;
  index?: number;
}

const { entry, index } = Astro.props;
const { data, slug } = entry;
const indexLabel =
  typeof index === 'number' ? String(index + 1).padStart(2, '0') : null;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Strip the locale prefix (en/foo, es/foo → foo) so URLs are clean.
const cleanSlug = slug.replace(/^(en|es)\//, '');
const href = localizePath(`/case-studies/${cleanSlug}/`, lang);
---

<a
  href={href}
  class="surface-card group flex flex-col h-full p-6 md:p-8 reveal-init"
>
  <div class="flex items-center justify-between mb-6">
    <span class="font-mono text-eyebrow uppercase text-text-dim">
      {indexLabel && <span class="mr-3">{indexLabel}</span>}
      {data.industry}
    </span>
    <span class="font-mono text-xs text-text-dim">{data.year}</span>
  </div>

  <h3
    class="font-display text-2xl md:text-[1.65rem] leading-tight text-balance group-hover:text-accent transition-colors"
  >
    {data.title}
  </h3>

  <p class="mt-4 text-text-muted leading-relaxed text-pretty">
    {data.summary}
  </p>

  {
    data.tags && data.tags.length > 0 && (
      <ul class="mt-6 flex flex-wrap gap-2">
        {data.tags.slice(0, 4).map((tag: string) => (
          <Tag size="sm">{tag}</Tag>
        ))}
      </ul>
    )
  }

  <div
    class="mt-auto pt-8 flex items-center justify-between text-xs font-mono text-text-muted"
  >
    <span>{data.role}</span>
    <span class="text-accent transition-transform group-hover:translate-x-1">
      {t('cs.read')}
    </span>
  </div>
</a>
