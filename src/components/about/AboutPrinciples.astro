---
import SectionHeading from '@components/ui/SectionHeading.astro';
import { getLangFromUrl, useTranslations } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const principles = [
  { title: t('ab.pr1.title'), body: t('ab.pr1.body') },
  { title: t('ab.pr2.title'), body: t('ab.pr2.body') },
  { title: t('ab.pr3.title'), body: t('ab.pr3.body') },
  { title: t('ab.pr4.title'), body: t('ab.pr4.body') },
];
---

<section class="container-x py-section relative">
  <SectionHeading
    eyebrow={t('ab.principles.eyebrow')}
    title={t('ab.principles.title')}
  />

  <ul
    class="mt-16 grid grid-cols-1 md:grid-cols-2 gap-px bg-border border border-border"
    data-principles
  >
    {
      principles.map((p, i) => (
        <li class="bg-bg reveal-init">
          <div
            class="group h-full p-8 md:p-10 transition-colors hover:bg-surface"
            data-principle-card
          >
            <span class="font-mono text-eyebrow uppercase text-accent">0{i + 1}</span>
            <h3 class="mt-7 font-display text-2xl md:text-[1.7rem] leading-tight text-balance">
              {p.title}
            </h3>
            <p class="mt-4 text-text-muted leading-relaxed text-pretty">
              {p.body}
            </p>
          </div>
        </li>
      ))
    }
  </ul>
</section>

<script>
  import { revealOnScroll, magneticHover } from '@/lib/motion';
  revealOnScroll('[data-principles] li', { stagger: 110, translateY: 18 });
  magneticHover('[data-principle-card]', 0.05);
</script>
