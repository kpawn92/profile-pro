---
import { site } from '@/lib/site';
import { getLangFromUrl, useTranslations, localizePath } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="container-x pb-section">
  <div class="border border-border p-10 md:p-16 reveal-init relative overflow-hidden">
    <div
      class="absolute inset-0 -z-10 pointer-events-none opacity-60"
      style="background:
        radial-gradient(ellipse 50% 50% at 30% 0%, rgba(201,168,106,0.10), transparent 70%),
        radial-gradient(ellipse 60% 60% at 100% 100%, rgba(201,168,106,0.05), transparent 70%);"
    >
    </div>

    <p class="eyebrow flex items-center gap-3">
      <span class="accent-rule" aria-hidden="true"></span>
      {t('wk.cta.eyebrow')}
    </p>

    <h2 class="mt-6 font-display text-display-l max-w-3xl text-balance">
      {t('wk.cta.title')}
    </h2>

    <p class="mt-6 max-w-xl text-lg text-text-muted leading-relaxed text-pretty">
      {t('wk.cta.body')}
    </p>

    <div class="mt-10 flex flex-wrap gap-4 items-center">
      <a
        href={`mailto:${site.email}`}
        class="inline-flex items-center gap-3 px-6 py-3 bg-text text-bg font-medium hover:bg-accent transition-colors"
      >
        {t('wk.cta.email')}
        <span aria-hidden="true">→</span>
      </a>
      <a
        href={localizePath('/about/', lang)}
        class="inline-flex items-center gap-3 px-6 py-3 border border-border hover:border-accent hover:text-accent transition-colors"
      >
        {t('wk.cta.about')}
      </a>
    </div>
  </div>
</section>

<script>
  import { revealOnScroll } from '@/lib/motion';
  revealOnScroll('.reveal-init');
</script>
