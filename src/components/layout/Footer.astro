---
import { site } from '@/lib/site';
import { getLangFromUrl, useTranslations } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const year = new Date().getFullYear();
---

<footer class="relative border-t border-border mt-24">
  <div class="container-x py-14 grid grid-cols-1 md:grid-cols-3 gap-12">
    <div>
      <div class="font-display text-lg">{site.name}</div>
      <p class="mt-3 text-sm text-text-muted max-w-xs leading-relaxed">
        {t('site.description')}
      </p>
    </div>

    <div>
      <h4 class="eyebrow mb-3">{t('footer.contact')}</h4>
      <a
        href={`mailto:${site.email}`}
        class="text-sm text-text hover:text-accent transition-colors link-underline"
      >
        {site.email}
      </a>
      <div class="mt-2 text-sm text-text-muted">{t('site.location')}</div>
    </div>

    <div>
      <h4 class="eyebrow mb-3">{t('footer.elsewhere')}</h4>
      <ul class="space-y-1.5 text-sm">
        <li>
          <a
            href={site.social.github}
            class="text-text-muted hover:text-text transition-colors"
            >GitHub</a
          >
        </li>
        <li>
          <a
            href={site.social.linkedin}
            class="text-text-muted hover:text-text transition-colors"
            >LinkedIn</a
          >
        </li>
      </ul>
    </div>
  </div>

  <div
    class="container-x py-6 border-t border-border flex items-center justify-between text-xs font-mono text-text-dim"
  >
    <span>{t('footer.rights', { year, name: site.name })}</span>
    <span>{t('footer.crafted')}</span>
  </div>
</footer>
