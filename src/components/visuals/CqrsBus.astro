---
// Animated CQRS message bus — three independent buses (command, query,
// event), each carrying a continuous gold comet from a producer to its
// handler. Reduced motion: static final state, no comets.
const rows = [
  { y: 66, producer: 'Command', bus: 'CommandBus', handler: 'Write model' },
  { y: 180, producer: 'Query', bus: 'QueryBus', handler: 'Read model' },
  { y: 294, producer: 'Event', bus: 'EventBus', handler: 'Subscribers' },
];
const PX = 80;
const HX = 560;
---

<figure class="relative w-full" data-cqrs-bus aria-label="CQRS message bus routing commands, queries and events">
  <svg viewBox="0 0 720 360" class="w-full h-auto" role="img">
    <defs>
      <radialGradient id="cqrs-glow" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="#C9A86A" stop-opacity="0.7" />
        <stop offset="100%" stop-color="#C9A86A" stop-opacity="0" />
      </radialGradient>
    </defs>

    {
      rows.map((r, i) => (
        <g>
          {/* bus base line */}
          <line x1="116" y1={r.y} x2="524" y2={r.y}
            stroke="#25252C" stroke-width="1" />

          {/* bus label */}
          <text x="320" y={r.y - 16} text-anchor="middle" class="font-mono"
            style="font-size:12px;letter-spacing:0.16em;fill:#5E6068;">
            {r.bus}
          </text>

          {/* producer */}
          <circle cx={PX} cy={r.y} r="11" fill="none" stroke="#35353E" stroke-width="1" />
          <circle cx={PX} cy={r.y} r="3" fill="#C9A86A" />
          <text x={PX} y={r.y + 32} text-anchor="middle" class="font-mono"
            style="font-size:11px;letter-spacing:0.04em;fill:#9295A0;">
            {r.producer}
          </text>

          {/* handler */}
          <circle data-handler-glow data-row={i} cx={HX} cy={r.y} r="20"
            fill="url(#cqrs-glow)" style="opacity:0;" />
          <circle data-handler data-row={i} cx={HX} cy={r.y} r="6"
            fill="#0A0A0B" stroke="#C9A86A" stroke-width="1.5" />
          <text x={HX} y={r.y + 32} text-anchor="middle" class="font-mono"
            style="font-size:11px;letter-spacing:0.04em;fill:#ECEDEE;">
            {r.handler}
          </text>

          {/* comet */}
          <circle data-comet-glow data-row={i} cx={PX} cy={r.y} r="9"
            fill="url(#cqrs-glow)" style="opacity:0;" />
          <circle data-comet-core data-row={i} cx={PX} cy={r.y} r="3.5"
            fill="#C9A86A" style="opacity:0;" />
        </g>
      ))
    }
  </svg>
</figure>

<style>
  @media (prefers-reduced-motion: reduce) {
    [data-cqrs-bus] [data-comet-glow],
    [data-cqrs-bus] [data-comet-core] {
      opacity: 0 !important;
    }
  }
</style>

<script>
  import anime from 'animejs/lib/anime.es.js';
  import { prefersReducedMotion } from '@/lib/motion';

  const root = document.querySelector<HTMLElement>('[data-cqrs-bus]');
  if (root && !prefersReducedMotion()) {
    const PX = 80;
    const HX = 560;
    const sel = (s: string) =>
      Array.from(root.querySelectorAll<SVGCircleElement>(s));
    const glows = sel('[data-comet-glow]');
    const cores = sel('[data-comet-core]');
    const hGlows = sel('[data-handler-glow]');
    const handlers = sel('[data-handler]');

    const fire = (i: number) => {
      const parts = [glows[i], cores[i]];
      parts.forEach((c) => c.setAttribute('cx', String(PX)));
      anime({ targets: parts, opacity: [0, 1], easing: 'easeOutQuad', duration: 220 });
      anime({
        targets: parts,
        cx: [PX, HX],
        easing: 'easeInOutCubic',
        duration: 1700,
        delay: 140,
        complete: () => {
          anime({ targets: parts, opacity: 0, easing: 'easeOutQuad', duration: 320 });
          anime({
            targets: hGlows[i],
            opacity: [0, 0.85, 0],
            easing: 'easeOutCubic',
            duration: 720,
          });
          anime({
            targets: handlers[i],
            r: [6, 8.5, 6],
            easing: 'easeInOutCubic',
            duration: 720,
          });
          setTimeout(() => fire(i), 1200 + Math.random() * 800);
        },
      });
    };

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          observer.unobserve(entry.target);
          rows_start();
        });
      },
      { threshold: 0.3 },
    );
    const rows_start = () => {
      [0, 1, 2].forEach((i) => setTimeout(() => fire(i), i * 620));
    };
    observer.observe(root);
  }
</script>
