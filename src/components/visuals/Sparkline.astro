---
import type { GhContributionWeek } from '@/lib/github';

interface Props {
  weeks: GhContributionWeek[];
  total: number;
  width?: number;
  height?: number;
}

const {
  weeks,
  total,
  width = 1100,
  height = 80,
} = Astro.props;

// Defensive: drop empty / malformed input
const series = weeks.map((w) => Math.max(0, w.total ?? 0));
const max = Math.max(1, ...series);

// Build the path (smooth area chart). Even spacing across the available width.
const stepX = series.length > 1 ? width / (series.length - 1) : 0;
const points = series.map((v, i) => {
  const x = i * stepX;
  const y = height - (v / max) * (height - 4) - 2; // 2px padding top/bottom
  return [x, y] as const;
});

const linePath =
  points.length > 0
    ? `M ${points[0][0]},${points[0][1]} ` +
      points
        .slice(1)
        .map(([x, y]) => `L ${x.toFixed(2)},${y.toFixed(2)}`)
        .join(' ')
    : '';

const areaPath =
  points.length > 0
    ? `${linePath} L ${width},${height} L 0,${height} Z`
    : '';

const lastX = points.length ? points[points.length - 1][0] : 0;
const lastY = points.length ? points[points.length - 1][1] : 0;
---

<figure class="reveal-init" data-sparkline aria-label={`${total} contributions in the last 52 weeks`}>
  <svg
    viewBox={`0 0 ${width} ${height}`}
    preserveAspectRatio="none"
    class="w-full h-20 md:h-24"
    role="img"
  >
    <defs>
      <linearGradient id="spark-fill" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="var(--color-accent)" stop-opacity="0.18" />
        <stop offset="100%" stop-color="var(--color-accent)" stop-opacity="0" />
      </linearGradient>
    </defs>

    <!-- Faint baseline -->
    <line
      x1="0"
      y1={height - 1}
      x2={width}
      y2={height - 1}
      stroke="var(--color-border)"
      stroke-width="1"
    />

    <!-- Area fill -->
    {areaPath && (
      <path
        d={areaPath}
        fill="url(#spark-fill)"
        data-sparkline-area
        style="opacity:0;"
      />
    )}

    <!-- Line -->
    {linePath && (
      <path
        d={linePath}
        fill="none"
        stroke="var(--color-accent)"
        stroke-width="1.25"
        stroke-linecap="round"
        stroke-linejoin="round"
        data-sparkline-line
        style="opacity:0;"
      />
    )}

    <!-- Last value pulse -->
    {points.length > 0 && (
      <circle
        cx={lastX}
        cy={lastY}
        r="2.5"
        fill="var(--color-accent)"
        data-sparkline-dot
        style="opacity:0;"
      />
    )}
  </svg>

  <figcaption
    class="mt-3 flex items-center justify-between font-mono text-[11px] uppercase tracking-wider text-text-dim"
  >
    <span>52 weeks</span>
    <span>
      <span class="text-text">{total.toLocaleString()}</span> contributions
    </span>
  </figcaption>
</figure>

<script>
  import anime from 'animejs/lib/anime.es.js';
  import { prefersReducedMotion } from '@/lib/motion';

  const containers = document.querySelectorAll<HTMLElement>('[data-sparkline]');
  if (containers.length) {
    const animate = (root: HTMLElement) => {
      const line = root.querySelector('[data-sparkline-line]') as SVGPathElement | null;
      const area = root.querySelector('[data-sparkline-area]') as SVGPathElement | null;
      const dot = root.querySelector('[data-sparkline-dot]') as SVGCircleElement | null;

      if (prefersReducedMotion()) {
        if (line) line.style.opacity = '1';
        if (area) area.style.opacity = '1';
        if (dot) dot.style.opacity = '1';
        return;
      }

      if (line) {
        const len = line.getTotalLength();
        line.style.strokeDasharray = `${len}`;
        line.style.strokeDashoffset = `${len}`;
        line.style.opacity = '1';
        anime({
          targets: line,
          strokeDashoffset: [len, 0],
          easing: 'easeInOutCubic',
          duration: 1400,
        });
      }
      if (area) {
        anime({
          targets: area,
          opacity: [0, 1],
          easing: 'easeOutCubic',
          duration: 900,
          delay: 400,
        });
      }
      if (dot) {
        anime({
          targets: dot,
          opacity: [0, 1],
          scale: [0, 1],
          easing: 'easeOutBack',
          duration: 500,
          delay: 1200,
        });
        anime({
          targets: dot,
          r: [
            { value: 4, duration: 800 },
            { value: 2.5, duration: 800 },
          ],
          easing: 'easeInOutSine',
          loop: true,
          delay: 1700,
        });
      }
    };

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          animate(entry.target as HTMLElement);
          observer.unobserve(entry.target);
        });
      },
      { threshold: 0.3 },
    );
    containers.forEach((c) => observer.observe(c));
  }
</script>
