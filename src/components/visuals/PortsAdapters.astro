---
// Animated ports & adapters (Hexagonal) diagram. A request flows from a
// driving adapter, through an inbound port, across the pure domain, out
// through an outbound port to a driven adapter. Reduced motion: static.
const C = { x: 330, y: 210 };
const R = 100;

const hexPath = (() => {
  const pts: string[] = [];
  for (let i = 0; i < 6; i++) {
    const a = (Math.PI / 180) * (60 * i - 90);
    pts.push(`${(C.x + R * Math.cos(a)).toFixed(1)},${(C.y + R * Math.sin(a)).toFixed(1)}`);
  }
  return 'M ' + pts.join(' L ') + ' Z';
})();

const portIn = [
  { x: 243.4, y: 178 },
  { x: 243.4, y: 242 },
];
const portOut = [
  { x: 416.6, y: 178 },
  { x: 416.6, y: 242 },
];
const adaptIn = [
  { x: 110, y: 150, label: 'HTTP' },
  { x: 110, y: 270, label: 'Scheduler' },
];
const adaptOut = [
  { x: 550, y: 150, label: 'PostgreSQL' },
  { x: 550, y: 270, label: 'Message queue' },
];

const flows = [0, 1].map(
  (i) =>
    `M ${adaptIn[i].x},${adaptIn[i].y} L ${portIn[i].x},${portIn[i].y} ` +
    `L ${C.x},${C.y} L ${portOut[i].x},${portOut[i].y} ` +
    `L ${adaptOut[i].x},${adaptOut[i].y}`,
);
const ports = [...portIn, ...portOut];
---

<figure class="relative w-full" data-ports aria-label="Hexagonal ports and adapters diagram">
  <svg viewBox="0 0 660 420" class="w-full h-auto" role="img">
    <defs>
      <radialGradient id="pa-glow" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="#C9A86A" stop-opacity="0.7" />
        <stop offset="100%" stop-color="#C9A86A" stop-opacity="0" />
      </radialGradient>
    </defs>

    <!-- flow tracks (faint) -->
    {flows.map((d, i) => (
      <path data-flow data-i={i} d={d} fill="none" stroke="#25252C" stroke-width="1" />
    ))}

    <!-- adapters -->
    {[...adaptIn, ...adaptOut].map((a, i) => (
      <g>
        {i >= 2 && (
          <circle data-adapter-glow data-i={i - 2} cx={a.x} cy={a.y} r="22"
            fill="url(#pa-glow)" style="opacity:0;" />
        )}
        <rect x={a.x - 9} y={a.y - 9} width="18" height="18" rx="2"
          fill="#131317" stroke="#35353E" stroke-width="1" />
        <text x={a.x} y={a.y + 30} text-anchor="middle" class="font-mono"
          style="font-size:11px;letter-spacing:0.03em;fill:#9295A0;">
          {a.label}
        </text>
      </g>
    ))}

    <!-- domain hexagon -->
    <path d={hexPath} fill="rgba(201,168,106,0.05)" stroke="#35353E" stroke-width="1" />
    <path data-hex-glow d={hexPath} fill="none" stroke="#C9A86A" stroke-width="1.5"
      style="opacity:0;" />
    <text x={C.x} y={C.y + 2} text-anchor="middle"
      style="font-family:'Fraunces',serif;font-style:italic;font-size:22px;fill:#ECEDEE;">
      Domain
    </text>
    <text x={C.x} y={C.y + 24} text-anchor="middle" class="font-mono"
      style="font-size:9px;letter-spacing:0.16em;text-transform:uppercase;fill:#5E6068;">
      pure · no framework
    </text>

    <!-- ports -->
    {ports.map((p) => (
      <rect x={p.x - 5} y={p.y - 5} width="10" height="10"
        fill="#0A0A0B" stroke="#C9A86A" stroke-width="1.25" />
    ))}

    <!-- side captions -->
    <text x="110" y="350" text-anchor="middle" class="font-mono"
      style="font-size:10px;letter-spacing:0.16em;text-transform:uppercase;fill:#5E6068;">
      driving
    </text>
    <text x="550" y="350" text-anchor="middle" class="font-mono"
      style="font-size:10px;letter-spacing:0.16em;text-transform:uppercase;fill:#5E6068;">
      driven
    </text>

    <!-- comets -->
    {[0, 1].map((i) => (
      <g>
        <circle data-comet-glow data-i={i} r="9" cx={adaptIn[i].x} cy={adaptIn[i].y}
          fill="url(#pa-glow)" style="opacity:0;" />
        <circle data-comet-core data-i={i} r="3.5" cx={adaptIn[i].x} cy={adaptIn[i].y}
          fill="#C9A86A" style="opacity:0;" />
      </g>
    ))}
  </svg>
</figure>

<style>
  @media (prefers-reduced-motion: reduce) {
    [data-ports] [data-comet-glow],
    [data-ports] [data-comet-core] {
      opacity: 0 !important;
    }
  }
</style>

<script>
  import anime from 'animejs/lib/anime.es.js';
  import { prefersReducedMotion } from '@/lib/motion';

  const root = document.querySelector<HTMLElement>('[data-ports]');
  if (root && !prefersReducedMotion()) {
    const sel = <T extends SVGElement>(s: string) =>
      Array.from(root.querySelectorAll<T>(s));
    const flowPaths = sel<SVGPathElement>('[data-flow]');
    const cores = sel<SVGCircleElement>('[data-comet-core]');
    const glows = sel<SVGCircleElement>('[data-comet-glow]');
    const adapterGlows = sel<SVGCircleElement>('[data-adapter-glow]');
    const hexGlow = root.querySelector<SVGPathElement>('[data-hex-glow]')!;

    const fire = (i: number) => {
      const path = flowPaths[i];
      const len = path.getTotalLength();
      const parts = [cores[i], glows[i]];
      const proxy = { d: 0 };
      let pulsed = false;
      parts.forEach((c) => (c.style.opacity = '1'));
      anime({ targets: parts, opacity: [0, 1], easing: 'easeOutQuad', duration: 220 });
      anime({
        targets: proxy,
        d: len,
        easing: 'easeInOutSine',
        duration: 2600,
        delay: 160,
        update: () => {
          const pt = path.getPointAtLength(proxy.d);
          parts.forEach((c) => {
            c.setAttribute('cx', pt.x.toFixed(1));
            c.setAttribute('cy', pt.y.toFixed(1));
          });
          if (!pulsed && proxy.d > len * 0.5) {
            pulsed = true;
            anime({
              targets: hexGlow,
              opacity: [0, 0.7, 0],
              easing: 'easeOutCubic',
              duration: 900,
            });
          }
        },
        complete: () => {
          anime({ targets: parts, opacity: 0, easing: 'easeOutQuad', duration: 320 });
          anime({
            targets: adapterGlows[i],
            opacity: [0, 0.85, 0],
            easing: 'easeOutCubic',
            duration: 720,
          });
          setTimeout(() => fire(i), 900 + Math.random() * 700);
        },
      });
    };

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          observer.unobserve(entry.target);
          [0, 1].forEach((i) => setTimeout(() => fire(i), i * 1100));
        });
      },
      { threshold: 0.3 },
    );
    observer.observe(root);
  }
</script>
