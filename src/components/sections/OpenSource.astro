---
import SectionHeading from '@components/ui/SectionHeading.astro';
import RepoCard from '@components/ui/RepoCard.astro';
import Sparkline from '@components/visuals/Sparkline.astro';
import LanguageBar from '@components/visuals/LanguageBar.astro';
import { getStats } from '@/lib/github';
import { site } from '@/lib/site';

const stats = await getStats();

const accountSinceYear = stats.profile
  ? new Date(stats.profile.createdAt).getFullYear()
  : null;

const totalStars = stats.totalStars;
const handle = stats.profile?.login ?? site.githubHandle;
const profileUrl = `https://github.com/${handle}`;

const hasAnyData =
  !!stats.profile ||
  stats.topRepos.length > 0 ||
  stats.languages.length > 0 ||
  !!stats.contributions;
---

{
  hasAnyData && (
    <section class="container-x py-section">
      <div class="flex items-end justify-between gap-8 flex-wrap">
        <SectionHeading
          eyebrow="Open source"
          title="A practice that informs the work."
          size="m"
        />
        <a
          href={profileUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm font-mono text-text-muted hover:text-accent transition-colors"
        >
          @{handle} →
        </a>
      </div>

      {stats.profile && (
        <dl
          class="mt-12 grid grid-cols-2 md:grid-cols-4 gap-px bg-border border border-border reveal-init"
        >
          <div class="bg-bg p-6">
            <dt class="eyebrow">Public repos</dt>
            <dd class="mt-2 font-display text-3xl text-balance">
              {stats.profile.publicRepos.toLocaleString()}
            </dd>
          </div>
          <div class="bg-bg p-6">
            <dt class="eyebrow">Stars earned</dt>
            <dd class="mt-2 font-display text-3xl text-accent text-balance">
              {totalStars >= 1000
                ? `${(totalStars / 1000).toFixed(1)}k`
                : totalStars.toLocaleString()}
            </dd>
          </div>
          <div class="bg-bg p-6">
            <dt class="eyebrow">Followers</dt>
            <dd class="mt-2 font-display text-3xl text-balance">
              {stats.profile.followers.toLocaleString()}
            </dd>
          </div>
          <div class="bg-bg p-6">
            <dt class="eyebrow">On GitHub since</dt>
            <dd class="mt-2 font-display text-3xl text-balance">
              {accountSinceYear}
            </dd>
          </div>
        </dl>
      )}

      {stats.contributions && (
        <div class="mt-16">
          <header class="flex items-end justify-between mb-5">
            <h3 class="eyebrow flex items-center gap-3">
              <span class="accent-rule" aria-hidden="true" /> Activity
            </h3>
            <span class="font-mono text-[11px] uppercase tracking-wider text-text-dim">
              Last 12 months
            </span>
          </header>
          <Sparkline
            weeks={stats.contributions.weeks}
            total={stats.contributions.total}
          />
        </div>
      )}

      {stats.languages.length > 0 && (
        <div class="mt-16">
          <header class="flex items-end justify-between mb-5">
            <h3 class="eyebrow flex items-center gap-3">
              <span class="accent-rule" aria-hidden="true" /> Languages
            </h3>
            <span class="font-mono text-[11px] uppercase tracking-wider text-text-dim">
              By bytes across active repos
            </span>
          </header>
          <LanguageBar languages={stats.languages} />
        </div>
      )}

      {stats.topRepos.length > 0 && (
        <div class="mt-16">
          <header class="flex items-end justify-between mb-6">
            <h3 class="eyebrow flex items-center gap-3">
              <span class="accent-rule" aria-hidden="true" /> Repositories
            </h3>
            <span class="font-mono text-[11px] uppercase tracking-wider text-text-dim">
              Selected · sorted by stars
            </span>
          </header>
          <div
            class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-px bg-border border border-border"
            data-repo-grid
          >
            {stats.topRepos.map((repo) => (
              <div class="bg-bg">
                <RepoCard repo={repo} />
              </div>
            ))}
          </div>
        </div>
      )}
    </section>
  )
}

<script>
  import { revealOnScroll } from '@/lib/motion';
  revealOnScroll('[data-repo-grid] .surface-card', { stagger: 90 });
</script>
