---
import { getCollection } from 'astro:content';
import SectionHeading from '@components/ui/SectionHeading.astro';
import ArticleCard from '@components/ui/ArticleCard.astro';

const articles = (await getCollection('articles', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);
---

<section class="container-x py-section">
  <div class="flex items-end justify-between gap-8 flex-wrap">
    <SectionHeading eyebrow="Writing" title="Notes on architecture & domain." size="m" />
    <a
      href="/writing/"
      class="text-sm font-mono text-text-muted hover:text-accent transition-colors"
    >
      All articles →
    </a>
  </div>

  <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-px bg-border border border-border" data-articles>
    {articles.map((entry) => (
      <div class="bg-bg">
        <ArticleCard entry={entry} />
      </div>
    ))}
  </div>
</section>

<script>
  import { revealOnScroll } from '@/lib/motion';
  revealOnScroll('[data-articles] .surface-card', { stagger: 100 });
</script>
