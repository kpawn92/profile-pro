---
import { specialization } from '@/lib/site';
import Tag from '@components/ui/Tag.astro';
import { getLangFromUrl, useTranslations, localizePath } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const titleWords = t('site.role').split(' ');
// Indices to italicise — covers both EN ("Full-Stack Developer") and ES
// ("Full-Stack Developer"). The role text repeats those two words across
// languages, so positions stay stable.
const italicIdx = lang === 'es' ? [1, 2] : [1, 2];
---

<section class="relative pt-36 md:pt-44 pb-section-sm">
  <div class="container-x">
    <p
      class="eyebrow flex items-center gap-3"
      data-hero-reveal="eyebrow"
      style="opacity:0;"
    >
      <span class="accent-rule" aria-hidden="true"></span>
      {t('hero.eyebrow')}
    </p>

    <h1
      class="font-display text-display-xl mt-8 max-w-[20ch] text-balance"
      data-hero-reveal="title"
    >
      {
        titleWords.map((w, i) => (
          <span class="word inline-block mr-[0.18em]" style="opacity:0;">
            {italicIdx.includes(i) ? <em class="italic font-light">{w}</em> : w}
          </span>
        ))
      }
    </h1>

    <p
      class="mt-8 max-w-2xl text-lg md:text-xl text-text-muted leading-relaxed text-pretty"
      data-hero-reveal="sub"
      style="opacity:0;"
    >
      {t('site.description')}
    </p>

    <ul
      class="mt-10 flex flex-wrap gap-2 max-w-3xl hero-tags"
      data-hero-reveal="tags"
    >
      {specialization.map((s) => <Tag size="sm">{s}</Tag>)}
    </ul>

    <div
      class="mt-12 flex flex-wrap items-center gap-6"
      data-hero-reveal="cta"
      style="opacity:0;"
    >
      <a
        href={localizePath('/case-studies/', lang)}
        class="inline-flex items-center gap-3 px-6 py-3 bg-text text-bg font-medium hover:bg-accent transition-colors"
      >
        {t('hero.cta.primary')}
        <span aria-hidden="true">→</span>
      </a>
      <a
        href={localizePath('/contact/', lang)}
        class="inline-flex items-center gap-3 px-6 py-3 border border-border hover:border-accent hover:text-accent transition-colors"
      >
        {t('hero.cta.secondary')}
      </a>
    </div>

    <!-- meta strip -->
    <div
      class="mt-20 pt-6 border-t border-border grid grid-cols-2 md:grid-cols-4 gap-6 reveal-init"
    >
      <div>
        <div class="eyebrow">{t('hero.meta.focus.label')}</div>
        <div class="mt-2 text-sm">{t('hero.meta.focus.value')}</div>
      </div>
      <div>
        <div class="eyebrow">{t('hero.meta.stack.label')}</div>
        <div class="mt-2 text-sm font-mono text-text-muted">
          {t('hero.meta.stack.value')}
        </div>
      </div>
      <div>
        <div class="eyebrow">{t('hero.meta.approach.label')}</div>
        <div class="mt-2 text-sm">{t('hero.meta.approach.value')}</div>
      </div>
      <div>
        <div class="eyebrow">{t('hero.meta.location.label')}</div>
        <div class="mt-2 text-sm">{t('site.location')}</div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-tags :global([data-tag]) {
    opacity: 0;
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-tags :global([data-tag]) {
      opacity: 1;
    }
  }
</style>

<script>
  import { playHeroReveal, revealOnScroll } from '@/lib/motion';
  playHeroReveal();
  revealOnScroll('.reveal-init');
</script>
