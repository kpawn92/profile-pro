---
import SectionHeading from '@components/ui/SectionHeading.astro';
import { getLangFromUrl, useTranslations } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const pillars = [
  { title: t('spec.p1.title'), body: t('spec.p1.body') },
  { title: t('spec.p2.title'), body: t('spec.p2.body') },
  { title: t('spec.p3.title'), body: t('spec.p3.body') },
];
---

<section class="container-x py-section">
  <SectionHeading eyebrow={t('spec.eyebrow')} title={t('spec.title')} />

  <ul
    class="mt-16 grid grid-cols-1 md:grid-cols-3 gap-px bg-border border border-border"
    data-pillars
  >
    {
      pillars.map((p, i) => (
        <li class="bg-bg flex flex-col p-7 md:p-9 reveal-init">
          <div class="font-mono text-eyebrow uppercase text-text-dim">
            0{i + 1}
          </div>
          <h3 class="mt-6 font-display text-2xl leading-tight text-balance">
            {p.title}
          </h3>
          <p class="mt-4 text-text-muted leading-relaxed text-pretty">
            {p.body}
          </p>
        </li>
      ))
    }
  </ul>
</section>

<script>
  import { revealOnScroll } from '@/lib/motion';
  revealOnScroll('[data-pillars] li', { stagger: 100 });
</script>
