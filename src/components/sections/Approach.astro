---
import SectionHeading from '@components/ui/SectionHeading.astro';
import FlowDiagram from '@components/visuals/FlowDiagram.astro';
import { getLangFromUrl, useTranslations } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const principles = [
  { n: '01', title: t('approach.p1.title'), body: t('approach.p1.body') },
  { n: '02', title: t('approach.p2.title'), body: t('approach.p2.body') },
  { n: '03', title: t('approach.p3.title'), body: t('approach.p3.body') },
  { n: '04', title: t('approach.p4.title'), body: t('approach.p4.body') },
];
---

<section class="container-x py-section">
  <SectionHeading eyebrow={t('approach.eyebrow')} title={t('approach.title')} />

  <div
    class="mt-16 grid grid-cols-1 lg:grid-cols-[1.05fr_1fr] gap-14 lg:gap-20 items-center"
  >
    <ol class="space-y-8 reveal-stagger" data-principles>
      {
        principles.map((p) => (
          <li class="grid grid-cols-[auto_1fr] gap-6 pb-8 border-b border-border last:border-b-0">
            <span class="font-mono text-eyebrow uppercase text-accent pt-1">
              {p.n}
            </span>
            <div>
              <h3 class="font-display text-xl md:text-2xl text-balance">
                {p.title}
              </h3>
              <p class="mt-3 text-text-muted leading-relaxed text-pretty">
                {p.body}
              </p>
            </div>
          </li>
        ))
      }
    </ol>

    <div class="reveal-init">
      <FlowDiagram />
      <p class="mt-6 text-center font-mono text-eyebrow uppercase text-text-dim">
        {t('approach.diagram.caption')}
      </p>
    </div>
  </div>
</section>

<script>
  import { revealOnScroll } from '@/lib/motion';
  revealOnScroll('[data-principles] li', { stagger: 90, translateY: 12 });
</script>
