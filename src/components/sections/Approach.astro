---
import SectionHeading from '@components/ui/SectionHeading.astro';
import FlowDiagram from '@components/visuals/FlowDiagram.astro';

const principles = [
  {
    n: '01',
    title: 'Domain at the core',
    body:
      'Pure domain logic — no frameworks, no infrastructure. The accounting rules, the inventory invariants, the order workflow live untouched by transport or persistence concerns.',
  },
  {
    n: '02',
    title: 'Ports & adapters',
    body:
      'Inbound use cases drive the domain through explicit ports; outbound integrations (DB, queues, third parties) implement adapters. Swappable, testable, observable.',
  },
  {
    n: '03',
    title: 'Tests as design pressure',
    body:
      'TDD as a feedback tool: red, green, refactor. Unit tests for the domain, integration tests at the boundaries, contract tests for external systems — pyramid stays in shape.',
  },
  {
    n: '04',
    title: 'Documented decisions',
    body:
      'ADRs for trade-offs, ubiquitous language for shared meaning, runbooks for the things that page someone at 3am. The system explains itself.',
  },
];
---

<section class="container-x py-section">
  <SectionHeading
    eyebrow="Approach"
    title="A disciplined approach to building software that an organisation can rely on for years."
  />

  <div class="mt-16 grid grid-cols-1 lg:grid-cols-[1.05fr_1fr] gap-14 lg:gap-20 items-center">
    <ol class="space-y-8 reveal-stagger" data-principles>
      {
        principles.map((p) => (
          <li class="grid grid-cols-[auto_1fr] gap-6 pb-8 border-b border-border last:border-b-0">
            <span class="font-mono text-eyebrow uppercase text-accent pt-1">
              {p.n}
            </span>
            <div>
              <h3 class="font-display text-xl md:text-2xl text-balance">
                {p.title}
              </h3>
              <p class="mt-3 text-text-muted leading-relaxed text-pretty">
                {p.body}
              </p>
            </div>
          </li>
        ))
      }
    </ol>

    <div class="reveal-init">
      <FlowDiagram />
      <p class="mt-6 text-center font-mono text-eyebrow uppercase text-text-dim">
        Hexagonal Architecture · Information Flow
      </p>
    </div>
  </div>
</section>

<script>
  import { revealOnScroll } from '@/lib/motion';
  revealOnScroll('[data-principles] li', { stagger: 90, translateY: 12 });
</script>
