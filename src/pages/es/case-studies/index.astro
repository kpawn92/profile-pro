---
import BaseLayout from '@layouts/BaseLayout.astro';
import WorkIntro from '@components/work/WorkIntro.astro';
import WorkEvidence from '@components/work/WorkEvidence.astro';
import WorkKernel from '@components/work/WorkKernel.astro';
import WorkIndex from '@components/work/WorkIndex.astro';
import WorkClose from '@components/work/WorkClose.astro';
import { getLangFromUrl, useTranslations } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<BaseLayout title={t('wk.meta.title')} description={t('wk.meta.desc')}>
  <WorkIntro />
  <WorkEvidence />
  <WorkKernel />
  <WorkIndex />
  <WorkClose />
</BaseLayout>
