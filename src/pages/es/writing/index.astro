---
import { getCollection } from 'astro:content';
import PageLayout from '@layouts/PageLayout.astro';
import ArticleCard from '@components/ui/ArticleCard.astro';
import { getLangFromUrl, useTranslations, localizePath } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const articles = (
  await getCollection(
    'articles',
    ({ data }) => !data.draft && data.lang === lang,
  )
).sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const grouped = articles.reduce<Record<string, typeof articles>>((acc, a) => {
  const year = a.data.pubDate.getFullYear().toString();
  (acc[year] ??= []).push(a);
  return acc;
}, {});

const years = Object.keys(grouped).sort((a, b) => Number(b) - Number(a));
---

<PageLayout
  title={t('writing.indexTitle')}
  eyebrow={t('writing.indexEyebrow')}
  lede={t('writing.indexLede')}
>
  <section class="container-x pb-section">
    {articles.length === 0 ? (
      <div class="border-t border-border pt-16 max-w-prose reveal-init">
        <h2 class="font-display text-display-m text-balance">
          {t('writing.empty.title')}
        </h2>
        <p class="mt-6 text-lg text-text-muted leading-relaxed text-pretty">
          {t('writing.empty.body')}
        </p>
        <a
          href={localizePath('/case-studies/', lang)}
          class="mt-8 inline-flex items-center gap-3 px-6 py-3 border border-border hover:border-accent hover:text-accent transition-colors text-sm"
        >
          {t('writing.empty.cta')}
        </a>
      </div>
    ) : (
      years.map((year) => (
        <div class="mb-16">
          <h2 class="font-mono text-eyebrow uppercase text-text-dim mb-2">
            {year}
          </h2>
          <div class="border-t border-border">
            {grouped[year].map((entry) => (
              <ArticleCard entry={entry} variant="list" />
            ))}
          </div>
        </div>
      ))
    )}
  </section>

  <script>
    import { revealOnScroll } from '@/lib/motion';
    revealOnScroll('.reveal-init');
  </script>
</PageLayout>
