---
import BaseLayout from '@layouts/BaseLayout.astro';
import AboutIntro from '@components/about/AboutIntro.astro';
import AboutValue from '@components/about/AboutValue.astro';
import AboutMethod from '@components/about/AboutMethod.astro';
import AboutKernel from '@components/about/AboutKernel.astro';
import AboutPrinciples from '@components/about/AboutPrinciples.astro';
import AboutStacks from '@components/about/AboutStacks.astro';
import AboutClose from '@components/about/AboutClose.astro';
import { getLangFromUrl, useTranslations } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<BaseLayout title={t('about.title')} description={t('about.meta.desc')}>
  <AboutIntro />
  <AboutValue />
  <AboutMethod />
  <AboutKernel />
  <AboutPrinciples />
  <AboutStacks />
  <AboutClose />
</BaseLayout>
